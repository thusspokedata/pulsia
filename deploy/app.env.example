# Copiar a deploy/app.env en la Pi (NO versionar app.env — vive solo en la Pi).
# El host de la DB es "db" (el servicio del compose), no localhost.
DATABASE_URL=postgres://pulsia:pulsia@db:5432/pulsia

# Clave AES-256-GCM de 32 bytes en hex (64 chars). Generar en la Pi con:
#   openssl rand -hex 32
# La API key de Anthropic NO va acá: se carga desde la app y se guarda encriptada en la DB.
ENCRYPTION_KEY=replace_me_64_hex_chars

# Puerto interno del backend (el compose lo publica como 3011).
PORT=8787

# Si cambiás la contraseña de Postgres, reflejala también en DATABASE_URL.
# POSTGRES_PASSWORD=pulsia
