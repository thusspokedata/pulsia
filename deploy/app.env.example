# Copiar a deploy/app.env en la Pi (NO versionar app.env — vive solo en la Pi).
# El host de la DB es "db" (el servicio del compose), no localhost.
DATABASE_URL=postgres://pulsia:pulsia@db:5432/pulsia

# Clave AES-256-GCM de 32 bytes en hex (64 chars). Generar en la Pi con:
#   openssl rand -hex 32
# La API key de Anthropic NO va acá: se carga desde la app y se guarda encriptada en la DB.
ENCRYPTION_KEY=replace_me_64_hex_chars

# Puerto interno del backend (el compose lo publica como 3011).
PORT=8787

# Código de invitación para el registro (requerido por el auth backend). Generar con:
#   openssl rand -hex 8
INVITE_CODE=replace_me

# Opcional: días de validez de la sesión de auth (default 4).
# SESSION_TTL_DAYS=4

# Token de admin/ops para escribir la última release (PUT /app/latest) — lo usa quien setea el APK
# nuevo tras cada build. Si falta, el PUT se rechaza (fail-closed). Generar con: openssl rand -hex 24
# ADMIN_TOKEN=replace_me

# Key de Anthropic por defecto del server: si un usuario no carga la suya en la app,
# se usa esta para generar. Opcional (si falta y el usuario tampoco tiene, la generación da 400).
# ANTHROPIC_API_KEY=sk-ant-...

# Modo single-user: saltea el login y usa el usuario por defecto (para la app actual
# sin auth). Dejar en "true" hasta que exista el login multi-usuario en la app.
SINGLE_USER_MODE=true

# La password de Postgres se fija en deploy/docker-compose.yml (POSTGRES_PASSWORD)
# y debe coincidir con la de DATABASE_URL de arriba. Cambiarla requiere editar ambos.
